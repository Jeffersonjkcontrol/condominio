# Copie para .env e ajuste os valores.

# Banco de dados (SQLite local). Para nuvem, troque para a URL do PostgreSQL/Supabase.
DATABASE_URL="file:./dev.db"

# Segredo do Auth.js. Gere um novo com:  npx auth secret
AUTH_SECRET="troque-por-um-segredo-aleatorio"

# Permite o Auth.js confiar no host (necessário em dev local / túnel)
AUTH_TRUST_HOST=true

# As chaves de IA (Claude/Gemini/ChatGPT) NÃO ficam aqui — são cadastradas
# na tela de Configurações do app e guardadas no banco de dados.
